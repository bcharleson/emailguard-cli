{
  "name": "emailguard-cli",
  "version": "0.1.4",
  "description": "CLI and MCP server for EmailGuard — email deliverability, blacklist monitoring, inbox placement testing, and spam analysis",
  "type": "module",
  "bin": {
    "emailguard": "dist/index.js",
    "emailguard-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "emailguard",
    "email",
    "deliverability",
    "blacklist",
    "dmarc",
    "spam",
    "inbox",
    "cli",
    "mcp",
    "ai-agent",
    "automation"
  ],
  "author": "Brandon Charleson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcharleson/emailguard-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
